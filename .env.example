# AI Job Application Copilot Environment Variables

# Database Setup
DATABASE_URL=sqlite:///./copilot.db
# DATABASE_URL=postgresql://copilot_user:copilot_pass@localhost:5432/copilot_db

# Authentication / Security
JWT_SECRET=super_secret_jwt_key_for_development
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Backend Configs
PORT=8000
UPLOAD_DIR=uploads

# AI / Large Language Model (Sprint 2+)
# Obtain a Gemini API Key to enable AI features
GEMINI_API_KEY=your_gemini_api_key_here
ENABLE_DEV_AI_ENDPOINTS=false
ENABLE_DEV_ADMIN_ENDPOINTS=false
CORS_ALLOWED_ORIGINS=*

# Frontend Configs
NEXT_PUBLIC_API_URL=http://localhost:8000
